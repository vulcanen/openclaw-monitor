# Default install registry: npmmirror (the npmjs upstream mirror in CN).
# Public — works for any contributor, fast inside CN, reachable from
# GitHub-hosted runners. `npm publish` ignores this and uses the
# `publishConfig.registry` field in package.json (which targets the
# public npmjs registry).
registry=https://registry.npmmirror.com/

save-exact=false
package-lock=true
