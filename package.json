{
  "name": "@vulcanen/openclaw-monitor",
  "version": "0.9.7",
  "description": "Self-contained real-time monitoring console for OpenClaw",
  "type": "module",
  "main": "./dist/index.js",
  "files": [
    "dist",
    "openclaw.plugin.json",
    "README.zh-CN.md"
  ],
  "scripts": {
    "build": "npm run build:plugin && npm run build:ui",
    "build:plugin": "tsc -p tsconfig.json",
    "build:ui": "cd ui && npm run build",
    "clean": "node -e \"require('node:fs').rmSync('dist',{recursive:true,force:true})\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:ui": "cd ui && npm run typecheck",
    "ui:install": "cd ui && npm install",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx}\" \"ui/src/**/*.{ts,tsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx}\" \"ui/src/**/*.{ts,tsx,css}\"",
    "prepublishOnly": "npm run clean && npm run build && npm run test"
  },
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "install": {
      "npmSpec": "@vulcanen/openclaw-monitor",
      "defaultChoice": "npm",
      "minHostVersion": ">=2026.5.7"
    },
    "compat": {
      "pluginApi": ">=2026.5.7"
    },
    "build": {
      "openclawVersion": "2026.5.7",
      "pluginSdkVersion": "2026.5.7"
    }
  },
  "devDependencies": {
    "@types/node": "^25.7.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "openclaw": "2026.5.7",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.3",
    "vitest": "^4.1.6"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "engines": {
    "node": ">=22"
  },
  "license": "MIT",
  "private": false
}
